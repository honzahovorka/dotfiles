#!/usr/bin/env bash

# Rebind xhci_hcd to recover disappeared USB devices, then reload uvcvideo.

set -euo pipefail

ids=(
    0000:c4:00.4
    0000:c6:00.0
    0000:c6:00.3
    0000:c6:00.4
)

for id in "${ids[@]}"; do
    echo "Rebinding $id"
    echo "$id" | sudo tee /sys/bus/pci/drivers/xhci_hcd/unbind >/dev/null
    sleep 2
    echo "$id" | sudo tee /sys/bus/pci/drivers/xhci_hcd/bind >/dev/null
    sleep 1
done

sudo modprobe -r uvcvideo
sudo modprobe uvcvideo

ls /dev/video*
