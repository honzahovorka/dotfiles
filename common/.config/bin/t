#!/usr/bin/env bash

# Jump to a directory using zoxide and attach/create a tmux session

if [[ $# -eq 0 ]]; then
    echo "Usage: t <directory>"
    echo "Jump to directory and attach/create tmux session"
    exit 1
fi

query="$1"

# Use zoxide to get the directory path
dir=$(zoxide query "$query" 2>/dev/null)

if [[ -z "$dir" ]]; then
    echo "No match found for '$query'"
    exit 1
fi

name="$(basename "$dir")"

# Try to attach to existing session, or create new one
if tmux has-session -t "$name" 2>/dev/null; then
    exec tmux attach -d -t "$name"
else
    # Create new session with nvim in first window, claude code in a vertical split.
    tmux new-session -d -s "$name" -c "$dir" -n "nvim" -x "$(tput cols)" -y "$(tput lines)" "nvim"
    tmux split-window -h -l 25% -t "$name:0" -c "$dir" "claude"
    # Create second window (shell)
    tmux new-window -t "$name" -c "$dir" -n "fish"
    # Create third window (codex)
    tmux new-window -t "$name" -c "$dir" -n "codex" "codex"
    # Select first window (nvim) and focus the nvim pane
    tmux select-window -t "$name:0"
    tmux select-pane -t "$name:0.0"
    exec tmux attach -d -t "$name"
fi
